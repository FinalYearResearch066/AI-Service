from sklearn.preprocessing import StandardScaler
import pickle
import pandas as pd

df = pd.read_csv("dataset1.csv")

df['day'] = pd.to_datetime(df['day'])
df['day_of_week'] = df['day'].dt.weekday

df['hour_dt'] = pd.to_datetime(df['hour'], format='%H:%M:%S')
df['hour'] = df['hour_dt'].dt.hour
df['minute'] = df['hour_dt'].dt.minute

df['duration'] = (df['t5'] - df['t0']) / 1000.0

scaler = StandardScaler()
scaler.fit(df[['hour', 'minute', 'day_of_week', 'duration']])

with open("models/time_scaler.pkl", "wb") as f:
    pickle.dump(scaler, f)
